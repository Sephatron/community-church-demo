---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  tone?: 'ink' | 'teal' | 'clay';
}
const { eyebrow, title, subtitle, image, imageAlt = '', tone = 'ink' } = Astro.props;
const toneBg = { ink: 'bg-ink', teal: 'bg-teal', clay: 'bg-clay' }[tone];
---
<section class:list={['relative isolate flex min-h-[54svh] items-end overflow-hidden', !image && 'grain', !image && toneBg]}>
  {image && (
    <>
      <Image src={image} alt={imageAlt} loading="eager" class="parallax absolute inset-0 -z-20 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink via-ink/70 to-ink/40"></div>
      <div class="absolute inset-0 -z-10 bg-gradient-to-b from-ink/55 to-transparent"></div>
    </>
  )}
  <div class="mx-auto w-full max-w-8xl px-5 pb-16 pt-32 lg:px-8 lg:pb-20">
    {eyebrow && (
      <p class="reveal flex items-center gap-3 font-display text-xs font-semibold uppercase tracking-[0.22em] text-clay-400 sm:text-sm">
        <span class="h-px w-8 bg-clay-400"></span>{eyebrow}
      </p>
    )}
    <h1 class="reveal mt-5 max-w-4xl font-display text-display font-black text-white">{title}</h1>
    {subtitle && (
      <p class="reveal mt-5 max-w-2xl text-lg leading-relaxed text-paper/85" style="--reveal-delay:120ms">{subtitle}</p>
    )}
  </div>
</section>
