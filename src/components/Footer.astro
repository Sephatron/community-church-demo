---
import { getEntry } from 'astro:content';
import { nav as fallbackNav, link, site } from '../data/site';
import { interpolate } from '../utils/interpolate';
import logoWhite from '../assets/img/logo-white.svg';

// ---------------------------------------------------------------------------
// Navigation — read from collection; fall back to site.ts if missing/empty.
// ---------------------------------------------------------------------------
const navEntry = await getEntry('navigation', 'main');
const nav = (navEntry?.data?.items && navEntry.data.items.length > 0)
  ? navEntry.data.items
  : fallbackNav;

// The footer uses the About and Community submenus directly.
const about = nav.find((n) => n.label === 'About')?.children ?? [];
const community = nav.find((n) => n.label === 'Community')?.children ?? [];

// ---------------------------------------------------------------------------
// Global settings — read from collection; fall back to site.ts values so a
// missing or blank settings file never breaks the footer.
// ---------------------------------------------------------------------------
const settingsEntry = await getEntry('site-settings', 'settings');
const s = settingsEntry?.data;

const tagline    = s?.churchTagline   ?? site.tagline;
const familyLine = s?.churchFamily    ?? site.family;
const charityNo  = s?.charityNo       ?? site.charityNo;
const facebook   = s?.socialFacebook  ?? site.socials.facebook;
const instagram  = s?.socialInstagram ?? site.socials.instagram;
const twitter    = s?.socialTwitter   ?? site.socials.twitter;
const soundcloud = s?.socialSoundCloud ?? site.socials.soundcloud;
const giveUrl    = s?.giveUrl         ?? site.giveUrl;

const bottomLine = s?.footerBottomLine ?? 'Concept demo — not the official website.';

// The map link is derived from the venue + area; not separately editable
// because it's a URL helper, not copy.
const mapQuery = `${s?.serviceVenue ?? site.service.venue} ${s?.serviceArea ?? site.service.area} EX14`;

const year = new Date().getFullYear();
---
<footer class="section-flow grain bg-ink text-paper">
  <div class="mx-auto max-w-8xl px-5 py-16 lg:px-8 lg:py-20">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1.2fr]">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <img src={logoWhite.src} alt="" width="48" height="48" class="h-12 w-12" />
          <span class="font-display text-xl font-bold">The Community Church</span>
        </div>
        <p class="mt-5 max-w-xs leading-relaxed text-paper/65">{tagline}</p>
        <div class="mt-6 flex gap-3">
          <a href={facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-clay">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V9z"/></svg>
          </a>
          <a href={instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-clay">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="3.8"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={twitter} target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-clay">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 3h3l-6.6 7.5L21.5 21h-6l-4.3-5.6L6.2 21H3.2l7-8L2.5 3h6.1l3.9 5.2L17.5 3z"/></svg>
          </a>
          <a href={soundcloud} target="_blank" rel="noopener noreferrer" aria-label="SoundCloud" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-clay">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 14v3M7 12v5M10 10v7M13 9v8h5a3 3 0 0 0 .3-6c-.4-2.6-2.6-4.5-5.3-4.5-.3 0-.7 0-1 .1"/></svg>
          </a>
        </div>
      </div>

      <!-- Explore -->
      <nav aria-label="Footer — Explore">
        <h2 class="font-display text-sm font-bold uppercase tracking-wider text-paper/50">Explore</h2>
        <ul class="mt-4 space-y-2.5 text-paper/75">
          <li><a class="transition-colors hover:text-clay-400" href={link('/im-new')}>I'm New</a></li>
          <li><a class="transition-colors hover:text-clay-400" href={link('/sundays')}>Sundays</a></li>
          <li><a class="transition-colors hover:text-clay-400" href={link('/sermons')}>Sermons</a></li>
          <li><a class="transition-colors hover:text-clay-400" href={link('/events')}>What's On</a></li>
        </ul>
      </nav>

      <!-- About + Community (nav from data) -->
      <nav aria-label="Footer — About and Community">
        <h2 class="font-display text-sm font-bold uppercase tracking-wider text-paper/50">About</h2>
        <ul class="mt-4 space-y-2.5 text-paper/75">
          {about.map((c) => <li><a class="transition-colors hover:text-clay-400" href={link(c.href)}>{c.label}</a></li>)}
        </ul>
        <h2 class="mt-7 font-display text-sm font-bold uppercase tracking-wider text-paper/50">Community</h2>
        <ul class="mt-4 space-y-2.5 text-paper/75">
          {community.map((c) => <li><a class="transition-colors hover:text-clay-400" href={link(c.href)}>{c.label}</a></li>)}
        </ul>
      </nav>

      <!-- Visit -->
      <div>
        <h2 class="font-display text-sm font-bold uppercase tracking-wider text-paper/50">Visit us</h2>
        {/*
          The visit line is reconstructed from discrete resolved values so the
          venue and time can be wrapped in bold spans without set:html.
          "Sunday" is hardcoded in the singular here — the serviceDay fact
          ("Sundays") is correct for card copy but grammatically wrong in the
          prose "every Sunday at…". The surrounding sentence is editorial prose,
          not a token-driven template.
        */}
        <p class="mt-4 leading-relaxed text-paper/75">
          We meet at <span class="font-semibold text-paper">{s?.serviceVenue ?? site.service.venue}</span> in {s?.serviceArea ?? site.service.area},<br />
          every Sunday at <span class="font-semibold text-paper">{s?.serviceTime ?? site.service.time}</span>.
        </p>
        <a href={`https://www.google.com/maps/search/${encodeURIComponent(mapQuery)}`} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-2 text-clay-400 transition-colors hover:text-clay">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.8"/></svg>
          Get directions
        </a>
        <a href={link('/give')} class="mt-6 inline-flex items-center justify-center rounded-full bg-clay px-6 py-3 font-display text-sm font-semibold text-white transition-colors hover:bg-clay-600">
          Give
        </a>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-white/10 pt-8 text-sm text-paper/60 md:flex-row md:items-center md:justify-between">
      <p>© {year} The Community Church · Registered Charity No. {charityNo}</p>
      <p class="text-paper/40">{bottomLine} {familyLine}</p>
    </div>
  </div>
</footer>
