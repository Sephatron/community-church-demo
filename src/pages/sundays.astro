---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
import { site, link } from '../data/site';
import sundayImg from '../assets/img/community-people.jpg';

const mapsUrl = `https://www.google.com/maps/search/${encodeURIComponent(site.mapQuery)}`;
const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent(site.mapQuery)}&output=embed`;

const practical = [
  { label: 'When', value: '10:30am – 12:00pm', note: 'Doors and coffee from 10:00am.' },
  { label: 'Where', value: 'The Beehive', note: 'Dowell Street, Honiton, EX14 1LZ.' },
  { label: 'Parking', value: 'On-site & nearby', note: 'Plus Lace Walk Car Park (near the Co-op).' },
  { label: 'Access', value: 'Step-free & a lift', note: 'Wheelchair and pushchair friendly, accessible toilets.' },
  { label: 'Hearing loop', value: 'Fitted throughout', note: 'The Beehive is equipped with a hearing loop.' },
  { label: 'Nursing mums', value: 'The Green Room', note: 'A quiet space is available — just ask for directions.' },
];
---
<BaseLayout title="Sundays" description="What to expect on a Sunday at The Community Church, Honiton — and everything you need to plan your visit.">
  <PageHero
    eyebrow="Sundays"
    title="Come as you are."
    subtitle="We gather every Sunday at 10:30am at The Beehive in Honiton. There's no need to dress up — just bring yourself."
    image={sundayImg}
    imageAlt="The church gathered on a Sunday morning at The Beehive"
  />

  <!-- Rhythm of a Sunday -->
  <section class="section-flow bg-paper py-20 lg:py-28">
    <div class="mx-auto grid max-w-8xl gap-12 px-5 lg:grid-cols-2 lg:gap-16 lg:px-8">
      <div class="reveal">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay">A Sunday with us</p>
        <h2 class="mt-4 font-display text-display font-black text-ink">Worship, the Bible, and good coffee.</h2>
      </div>
      <div class="reveal richtext" style="--reveal-delay:120ms">
        <p>Join us on a Sunday morning as your first step into our church community — you matter to us.</p>
        <p>Our mornings start with contemporary <strong>worship</strong>, followed by uplifting <strong>Bible teaching</strong> and more worship. Before and after we gather, enjoy a complimentary tea or coffee as we connect with new people.</p>
        <p>Our meetings are casual and inclusive, with engaging programmes for kids and youth aged 0–17. Your presence makes a difference, and we can't wait to meet you.</p>
      </div>
    </div>
  </section>

  <!-- Practical info -->
  <section class="section-flow grain bg-ink py-20 text-paper lg:py-28">
    <div class="mx-auto max-w-8xl px-5 lg:px-8">
      <div class="reveal max-w-2xl">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay-400">Plan your visit</p>
        <h2 class="mt-4 font-display text-display font-black">The practical bits.</h2>
      </div>
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {practical.map((p, i) => (
          <div class="reveal rounded-[1.5rem] bg-white/[0.04] p-7 ring-1 ring-white/10" style={`--reveal-delay:${i * 60}ms`}>
            <p class="font-display text-sm font-semibold uppercase tracking-wider text-clay-400">{p.label}</p>
            <p class="mt-2 font-display text-xl font-bold">{p.value}</p>
            <p class="mt-1.5 leading-relaxed text-paper/65">{p.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kids & youth -->
  <section class="section-flow bg-paper py-20 lg:py-28">
    <div class="mx-auto max-w-8xl px-5 lg:px-8">
      <div class="reveal max-w-2xl">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay">Kids &amp; youth</p>
        <h2 class="mt-4 font-display text-display font-black text-ink">There's a place for the whole family.</h2>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-2">
        <div class="reveal rounded-[1.5rem] bg-ink/[0.03] p-8 ring-1 ring-ink/10">
          <h3 class="font-display text-2xl font-bold text-ink">Children · 0–10</h3>
          <p class="mt-3 leading-relaxed text-ink/70">Creche for babies, toddlers and preschoolers, and <strong>Activ8</strong> for ages 5–11 — worship, Bible stories, friends and a lot of fun, every Sunday.</p>
          <a href={link('/community/children')} class="mt-5 inline-flex items-center gap-1.5 font-semibold text-clay hover:text-clay-600">Children's Ministry →</a>
        </div>
        <div class="reveal rounded-[1.5rem] bg-ink/[0.03] p-8 ring-1 ring-ink/10" style="--reveal-delay:120ms">
          <h3 class="font-display text-2xl font-bold text-ink">Youth · 11–17</h3>
          <p class="mt-3 leading-relaxed text-ink/70">Our youth meet on Sundays through the month, every Friday evening at Meadow View, and head away each year to the Satellites festival.</p>
          <a href={link('/community/youth')} class="mt-5 inline-flex items-center gap-1.5 font-semibold text-clay hover:text-clay-600">Youth Ministry →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="section-flow grain bg-teal py-20 text-paper lg:py-28">
    <div class="mx-auto grid max-w-8xl items-center gap-12 px-5 lg:grid-cols-2 lg:gap-16 lg:px-8">
      <div class="reveal">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-sand">Finding us</p>
        <h2 class="mt-4 font-display text-display font-black">The Beehive, Honiton.</h2>
        <p class="mt-6 text-lg leading-relaxed text-paper/80">You'll find us in the heart of Honiton on Dowell Street. There's parking on-site and at Lace Walk Car Park nearby.</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={link('/im-new')} variant="outline">I'm new — what to expect</Button>
          <Button href={mapsUrl} variant="outline" external>Get directions</Button>
        </div>
      </div>
      <div class="reveal overflow-hidden rounded-[2rem] shadow-xl ring-1 ring-black/20" style="--reveal-delay:120ms">
        <iframe title="Map showing The Beehive, Honiton" src={mapEmbed} width="100%" height="420" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
