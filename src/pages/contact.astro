---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';

const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent('The King’s Centre High Street Honiton EX14 1DH')}&output=embed`;
const places = [
  { name: 'Church Office', lines: ['The King’s Centre, Lees Buildings', 'High Street, Honiton, EX14 1DH'], email: site.contact.email, phone: site.contact.phone },
  { name: 'Honiton Foodbank', lines: ['The King’s Centre, Honiton', 'Open Tuesdays & Fridays, 12:30–3pm'], email: site.contact.foodbankEmail, phone: site.contact.foodbankPhone },
  { name: 'Meadow View Chapel', lines: ['Meadow View, Kings Street', 'Honiton, EX14 1AD'] },
];
---
<BaseLayout title="Contact" description="Get in touch with The Community Church, Honiton — office, foodbank and Meadow View Chapel.">
  <PageHero
    eyebrow="Contact"
    title="We'd love to hear from you."
    subtitle="Whether you've a question, need a hand, or just want to say hello — here's how to reach us."
    tone="ink"
  />

  <section class="section-flow bg-paper py-20 lg:py-28">
    <div class="mx-auto grid max-w-8xl gap-12 px-5 lg:grid-cols-[1fr_1.1fr] lg:gap-16 lg:px-8">
      <!-- Details -->
      <div class="reveal space-y-5">
        {places.map((p) => (
          <div class="rounded-[1.5rem] bg-ink/[0.03] p-7 ring-1 ring-ink/10">
            <h2 class="font-display text-xl font-bold text-ink">{p.name}</h2>
            <div class="mt-3 space-y-0.5 text-ink/70">
              {p.lines.map((l) => <p>{l}</p>)}
            </div>
            <div class="mt-4 flex flex-wrap gap-x-6 gap-y-1.5 text-sm">
              {p.email && <a href={`mailto:${p.email}`} class="font-semibold text-clay hover:text-clay-600">{p.email}</a>}
              {p.phone && <a href={`tel:${p.phone.replace(/\s/g, '')}`} class="font-semibold text-clay hover:text-clay-600">{p.phone}</a>}
            </div>
          </div>
        ))}
      </div>

      <!-- Form -->
      <div class="reveal" style="--reveal-delay:120ms">
        <form id="contact-form" class="rounded-[2rem] bg-ink p-8 text-paper lg:p-10">
          <h2 class="font-display text-2xl font-black">Send us a message</h2>
          <p class="mt-2 text-sm text-paper/55">We aim to reply within a couple of days.</p>
          <div class="mt-7 space-y-4">
            <label class="block">
              <span class="text-sm font-medium text-paper/70">Your name</span>
              <input name="name" required class="mt-1.5 w-full rounded-xl bg-white/[0.06] px-4 py-3 text-paper placeholder:text-paper/40 ring-1 ring-white/15 focus:ring-clay focus:outline-none" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-paper/70">Your email</span>
              <input name="email" type="email" required class="mt-1.5 w-full rounded-xl bg-white/[0.06] px-4 py-3 text-paper placeholder:text-paper/40 ring-1 ring-white/15 focus:ring-clay focus:outline-none" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-paper/70">Subject</span>
              <input name="subject" class="mt-1.5 w-full rounded-xl bg-white/[0.06] px-4 py-3 text-paper placeholder:text-paper/40 ring-1 ring-white/15 focus:ring-clay focus:outline-none" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-paper/70">Message</span>
              <textarea name="message" rows="4" class="mt-1.5 w-full rounded-xl bg-white/[0.06] px-4 py-3 text-paper placeholder:text-paper/40 ring-1 ring-white/15 focus:ring-clay focus:outline-none"></textarea>
            </label>
          </div>
          <button type="submit" class="mt-6 w-full rounded-full bg-clay px-6 py-3.5 font-display font-semibold text-white transition-colors hover:bg-clay-600">Send message</button>
          <p id="contact-note" class="mt-4 text-center text-xs text-paper/45">This demo form opens your email app, pre-addressed to the church office.</p>
        </form>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="section-flow grain bg-teal py-16 lg:py-20">
    <div class="mx-auto max-w-8xl px-5 lg:px-8">
      <div class="reveal overflow-hidden rounded-[2rem] shadow-xl ring-1 ring-black/20">
        <iframe title="Map showing The King’s Centre, Honiton" src={mapEmbed} width="100%" height="420" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ office: site.contact.email }}>
    const form = document.getElementById('contact-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const subject = data.get('subject') || 'Website enquiry';
      const body = `From: ${data.get('name')} (${data.get('email')})\n\n${data.get('message')}`;
      window.location.href = `mailto:${office}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</BaseLayout>
