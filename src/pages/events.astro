---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { events, eventCategories } from '../data/events';

// Recurring rhythm first, then one-offs by date.
const sorted = [...events].sort((a, b) => {
  if (a.recurring && !b.recurring) return -1;
  if (!a.recurring && b.recurring) return 1;
  return (a.date || '').localeCompare(b.date || '');
});
const catColour: Record<string, string> = {
  'Whole church': 'bg-clay/15 text-clay-600',
  'Youth': 'bg-teal/15 text-teal-600',
  'Children & Families': 'bg-sand/25 text-clay-600',
  'Foodbank': 'bg-ink/10 text-ink',
  'Community': 'bg-clay/15 text-clay-600',
};
---
<BaseLayout title="What's On" description="What's on at The Community Church, Honiton — Sundays, the foodbank, youth, and seasonal events. Filter by category.">
  <PageHero
    eyebrow="What's on"
    title="There's always something on."
    subtitle="From our weekly rhythm to one-off celebrations, here's how to get involved. Filter by what you're looking for."
    tone="teal"
  />

  <section class="section-flow bg-paper py-16 lg:py-24">
    <div class="mx-auto max-w-8xl px-5 lg:px-8">
      <!-- Category chips -->
      <div class="reveal flex flex-wrap gap-2.5" role="group" aria-label="Filter events by category">
        <button type="button" data-cat="all" class="event-chip is-active rounded-full px-5 py-2.5 font-display text-sm font-semibold ring-1 bg-transparent text-ink ring-ink/15 transition-colors hover:bg-ink/5">All</button>
        {eventCategories.map((c) => (
          <button type="button" data-cat={c} class="event-chip rounded-full px-5 py-2.5 font-display text-sm font-semibold ring-1 bg-transparent text-ink ring-ink/15 transition-colors hover:bg-ink/5">{c}</button>
        ))}
      </div>
      <p class="mt-5 text-sm text-ink/65"><span id="event-count">{sorted.length}</span> events</p>

      <!-- Cards -->
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {sorted.map((e) => (
          <article data-event data-category={e.category} class="flex flex-col rounded-[1.75rem] bg-ink/[0.03] p-8 ring-1 ring-ink/10">
            <div class="flex items-center justify-between gap-3">
              <span class={`rounded-full px-3 py-1 text-xs font-semibold ${catColour[e.category] || 'bg-ink/10 text-ink'}`}>{e.category}</span>
              {e.recurring && <span class="rounded-full bg-ink px-3 py-1 text-xs font-semibold text-paper">Weekly</span>}
            </div>
            <h2 class="mt-4 font-display text-2xl font-black leading-tight text-ink">{e.title}</h2>
            <p class="mt-3 flex items-center gap-2 font-semibold text-clay"><span aria-hidden="true">●</span> {e.when}</p>
            <p class="mt-1 text-sm text-ink/55">{e.location}</p>
            <p class="mt-4 flex-1 leading-relaxed text-ink/70">{e.description}</p>
          </article>
        ))}
      </div>
      <p id="event-empty" style="display:none" class="mt-12 text-center text-ink/60">Nothing in that category right now — try another.</p>
    </div>
  </section>

  <script>
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.event-chip'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-event]'));
    const empty = document.getElementById('event-empty');
    const ACTIVE = ['is-active', 'bg-ink', 'text-paper', 'ring-ink'];
    const INACTIVE = ['bg-transparent', 'text-ink', 'ring-ink/15', 'hover:bg-ink/5'];
    function paint(btn: HTMLButtonElement, on: boolean) {
      btn.classList.remove(...(on ? INACTIVE : ACTIVE));
      btn.classList.add(...(on ? ACTIVE : INACTIVE));
    }
    chips.forEach((c) => paint(c, c.dataset.cat === 'all'));
    const countEl = document.getElementById('event-count');
    function filter(cat: string) {
      let visible = 0;
      cards.forEach((c) => {
        const show = cat === 'all' || c.dataset.category === cat;
        c.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = String(visible);
      if (empty) empty.style.display = visible ? 'none' : '';
    }
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => paint(c, c === chip));
        filter(chip.dataset.cat || 'all');
      });
    });
  </script>
</BaseLayout>
