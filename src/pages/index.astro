---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { site, link } from '../data/site';
import heroImg from '../assets/img/honiton-worship.jpg';
import welcomeImg from '../assets/img/church-life.jpg';
import teachingImg from '../assets/img/community-people.jpg';
import sundayImg from '../assets/img/christmas.jpg';
import youthImg from '../assets/img/youth-event.jpg';
import satellitesImg from '../assets/img/youth-trip.jpg';

const mapsUrl = `https://www.google.com/maps/search/${encodeURIComponent(site.mapQuery)}`;

// ---------------------------------------------------------------------------
// Next event: the earliest upcoming one-off event from the Content Collection.
// Falls back gracefully to null if no dated events exist (block is hidden).
// We keep the Play On poster image hardcoded here for the demo — a Phase 1/2
// task would wire a per-event image field and resolve it dynamically.
// ---------------------------------------------------------------------------
const today = new Date().toISOString().slice(0, 10); // "YYYY-MM-DD"
const allEvents = await getCollection('events');
const nextEvent = allEvents
  .map((e) => e.data)
  .filter((e) => !e.recurring && e.date && e.date >= today)
  .sort((a, b) => (a.date ?? '').localeCompare(b.date ?? ''))[0] ?? null;

// ---------------------------------------------------------------------------
// Site settings: read the CMS-editable theme token for the hero accent word.
// Falls back to "Jesus" if settings are missing so the page never breaks.
// ---------------------------------------------------------------------------
const settingsEntries = await getCollection('site-settings');
const heroAccentText = settingsEntries[0]?.data?.heroAccentText ?? 'Jesus';
---
<BaseLayout overHero={true}>
  <!-- ============ HERO ============ -->
  <section class="relative isolate flex min-h-[100svh] items-end overflow-hidden">
    <Image src={heroImg} alt="The church gathered together in worship, hands raised" loading="eager" class="parallax absolute inset-0 -z-20 h-full w-full object-cover" />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink via-ink/75 to-ink/25"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink/80 via-ink/20 to-transparent"></div>

    <div class="mx-auto w-full max-w-8xl px-5 pb-24 pt-36 lg:px-8 lg:pb-32">
      <p class="reveal flex items-center gap-3 font-display text-xs font-semibold uppercase tracking-[0.22em] text-clay-400 sm:text-sm">
        <span class="h-px w-8 bg-clay-400"></span> The Community Church · Honiton
      </p>
      <h1 class="reveal mt-6 max-w-4xl font-display text-hero font-black text-white">
        Lives changed by <span class="text-clay-400">{heroAccentText}</span> in East Devon.
      </h1>
      <p class="reveal mt-7 max-w-xl text-lg leading-relaxed text-paper/85" style="--reveal-delay:120ms">
        An ordinary community of people finding a bigger story. We meet at {site.service.venue}, {site.service.area}, every Sunday at {site.service.time} — and you're warmly invited.
      </p>
      <div class="reveal mt-9 flex flex-wrap items-center gap-3" style="--reveal-delay:240ms">
        <Button href={link('/im-new')} variant="primary">Plan your first visit</Button>
        <Button href={link('/sundays')} variant="outline">What happens on a Sunday</Button>
      </div>
    </div>

  </section>

  <!-- ============ WELCOME ============ -->
  <section class="section-flow bg-paper py-20 lg:py-28">
    <div class="mx-auto grid max-w-8xl items-center gap-12 px-5 lg:grid-cols-2 lg:gap-16 lg:px-8">
      <div class="reveal">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay">Welcome</p>
        <h2 class="mt-4 font-display text-display font-black text-ink">However you arrive, there's a place for you here.</h2>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">
          Whether you've followed Jesus for decades, wandered away years ago, or you're simply curious — you'll find a warm welcome, honest conversation and zero pressure. Come exactly as you are.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-ink/70">{site.family}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={link('/im-new')} variant="ghost">I'm new here</Button>
          <Button href={link('/about/vision-values')} variant="ghost">Our vision &amp; values</Button>
        </div>
      </div>
      <div class="reveal" style="--reveal-delay:120ms">
        <div class="relative">
          <Image src={welcomeImg} alt="Families and children worshipping together at The Beehive" class="aspect-[4/3] w-full rounded-[2rem] object-cover shadow-2xl" />
          <div class="absolute -bottom-6 -left-4 hidden rounded-3xl bg-clay px-7 py-6 text-white shadow-xl sm:block">
            <p class="font-display text-4xl font-black leading-none">90<span class="align-top text-lg">min</span></p>
            <p class="mt-1.5 text-sm leading-snug text-white/85">music, teaching<br />&amp; good coffee</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PLAN YOUR SUNDAY ============ -->
  <section class="section-flow grain bg-ink py-20 text-paper lg:py-28">
    <div class="mx-auto max-w-8xl px-5 lg:px-8">
      <div class="reveal max-w-2xl">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay-400">Plan your Sunday</p>
        <h2 class="mt-4 font-display text-display font-black">Everything you need before you come.</h2>
      </div>
      <div class="mt-14 grid gap-5 md:grid-cols-3">
        <div class="reveal rounded-[1.75rem] bg-white/[0.04] p-8 ring-1 ring-white/10">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-clay/15 text-clay-400">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-6 font-display text-xl font-bold">When</h3>
          <p class="mt-2 leading-relaxed text-paper/70">{site.service.day} at <span class="font-semibold text-paper">{site.service.time}</span>. Doors and coffee from {site.service.arrive} — arrive early and say hello.</p>
        </div>
        <div class="reveal rounded-[1.75rem] bg-white/[0.04] p-8 ring-1 ring-white/10" style="--reveal-delay:120ms">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-clay/15 text-clay-400">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none"><path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11z" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="10" r="2.4" stroke="currentColor" stroke-width="1.8"/></svg>
          </div>
          <h3 class="mt-6 font-display text-xl font-bold">Where</h3>
          <p class="mt-2 leading-relaxed text-paper/70">{site.service.venue}, in the centre of {site.service.area}. Step-free access and parking nearby.</p>
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1.5 font-semibold text-clay-400 hover:text-clay">Get directions →</a>
        </div>
        <div class="reveal rounded-[1.75rem] bg-white/[0.04] p-8 ring-1 ring-white/10" style="--reveal-delay:240ms">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-clay/15 text-clay-400">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none"><path d="M4 6h16M4 12h16M4 18h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-6 font-display text-xl font-bold">What to expect</h3>
          <p class="mt-2 leading-relaxed text-paper/70">Around 90 minutes of live music, a down-to-earth talk, groups for kids and youth, and time over coffee afterwards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERMONS / SOUNDCLOUD ============ -->
  <section class="section-flow bg-paper py-20 lg:py-28">
    <div class="mx-auto grid max-w-8xl items-center gap-12 px-5 lg:grid-cols-2 lg:gap-16 lg:px-8">
      <div class="reveal">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay">Sermons</p>
        <h2 class="mt-4 font-display text-display font-black text-ink">Catch up on a recent talk.</h2>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">
          Missed a Sunday, or want to go deeper during the week? Every talk is free to stream, whenever suits you.
        </p>
        <div class="mt-8">
          <Button href={link('/sermons')} variant="ghost">Browse all sermons</Button>
        </div>
      </div>
      <div class="reveal overflow-hidden rounded-[2rem] shadow-xl ring-1 ring-ink/5" style="--reveal-delay:120ms">
        <iframe
          title="Latest sermons from The Community Church on SoundCloud"
          width="100%"
          height="350"
          scrolling="no"
          frameborder="no"
          loading="lazy"
          src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/thecommunitychurchhoniton&color=%23E64A19&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&visual=true"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ============ FIND YOUR PLACE (tiles) ============ -->
  <section class="section-flow grain bg-teal py-20 text-paper lg:py-28">
    <div class="mx-auto max-w-8xl px-5 lg:px-8">
      <div class="reveal flex flex-col justify-between gap-6 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-sand">Find your place</p>
          <h2 class="mt-4 font-display text-display font-black">There's far more to us than Sunday.</h2>
        </div>
        <a href={link('/community')} class="inline-flex shrink-0 items-center gap-2 font-display font-semibold text-paper hover:text-sand">All ministries →</a>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <a href={link('/sundays')} class="reveal group relative flex h-80 flex-col justify-end overflow-hidden rounded-[1.75rem]">
          <Image src={sundayImg} alt="A Sunday gathering at The Beehive" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-transparent"></div>
          <div class="relative p-6">
            <h3 class="font-display text-2xl font-bold">Sundays</h3>
            <p class="mt-1 text-paper/75">What a morning looks like →</p>
          </div>
        </a>
        <a href={link('/community/youth')} class="reveal group relative flex h-80 flex-col justify-end overflow-hidden rounded-[1.75rem]" style="--reveal-delay:100ms">
          <Image src={youthImg} alt="Young people at a summer youth event" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-transparent"></div>
          <div class="relative p-6">
            <h3 class="font-display text-2xl font-bold">Children &amp; Youth</h3>
            <p class="mt-1 text-paper/75">Space to grow and belong →</p>
          </div>
        </a>
        <a href={link('/community/foodbank')} class="reveal grain group relative flex h-80 flex-col justify-between overflow-hidden rounded-[1.75rem] bg-clay p-6 text-white" style="--reveal-delay:200ms">
          <svg class="h-10 w-10 text-white/90" viewBox="0 0 24 24" fill="none"><path d="M5 9h14l-1 11H6L5 9z" stroke="currentColor" stroke-width="1.6"/><path d="M9 9V6a3 3 0 0 1 6 0v3" stroke="currentColor" stroke-width="1.6"/></svg>
          <div>
            <h3 class="font-display text-2xl font-bold">Honiton Foodbank</h3>
            <p class="mt-1 text-white/85">Practical love for our town →</p>
          </div>
        </a>
        <a href={link('/community/satellites')} class="reveal group relative flex h-80 flex-col justify-end overflow-hidden rounded-[1.75rem]" style="--reveal-delay:300ms">
          <Image src={satellitesImg} alt="The youth team away at a festival" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-transparent"></div>
          <div class="relative p-6">
            <h3 class="font-display text-2xl font-bold">Satellites</h3>
            <p class="mt-1 text-paper/75">Our youth community →</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ NEXT EVENT ============ -->
  <!-- Block is only rendered when there is at least one upcoming dated event in the collection. -->
  <!-- Image removed: the hardcoded Play On poster did not match the dynamically-selected
       next event. A per-event image field is a later phase; until then this is text-only. -->
  {nextEvent && (
    <section class="section-flow bg-paper py-20 lg:py-28">
      <div class="mx-auto max-w-3xl px-5 lg:px-8">
        <div class="reveal">
          <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay">What's on next</p>
          <h2 class="mt-4 font-display text-display font-black text-ink">{nextEvent.title}</h2>
          <div class="mt-6 flex flex-wrap gap-x-8 gap-y-3 text-ink/70">
            <span class="inline-flex items-center gap-2"><span class="text-clay">●</span> {nextEvent.when}</span>
            <span class="inline-flex items-center gap-2"><span class="text-clay">●</span> {nextEvent.location}</span>
          </div>
          <p class="mt-6 text-lg leading-relaxed text-ink/70">
            {nextEvent.description}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href={link('/events')} variant="ghost">See all events</Button>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ============ GIVE ============ -->
  <section class="section-flow grain relative isolate bg-clay py-20 text-white lg:py-24">
    <div class="mx-auto max-w-3xl px-5 text-center lg:px-8">
      <h2 class="reveal font-display text-display font-black">Partner with what God is doing in East Devon.</h2>
      <p class="reveal mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/85" style="--reveal-delay:120ms">
        Everything we do — Sundays, the foodbank, work with families and young people — is made possible by the generosity of ordinary people. Thank you.
      </p>
      <div class="reveal mt-9 flex justify-center" style="--reveal-delay:240ms">
        <Button href={site.giveUrl} variant="ghost" external>Give to the church</Button>
      </div>
    </div>
  </section>
</BaseLayout>
