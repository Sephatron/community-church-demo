---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Button from '../../components/Button.astro';
import { link } from '../../data/site';
import heroImg from '../../assets/img/christmas.jpg';

const groups = [
  { name: 'Creche', age: '0–4', body: 'A safe, happy space for babies, toddlers and preschoolers — free play, songs and Bible stories.' },
  { name: 'Activ8', age: '5–11', body: 'Our children’s group meets during most of the Sunday meeting to worship, learn about God, make friends and have lots of fun.' },
];
---
<BaseLayout title="Children's Ministry" description="Children's ministry at The Community Church, Honiton — creche and Activ8 (ages 5–11), with DBS-checked, vetted leaders.">
  <PageHero
    eyebrow="Community"
    title="Children matter."
    subtitle="Your children are important to us, and we take their care and protection very seriously. They're a valued part of our church family."
    image={heroImg}
    imageAlt="Children and families together on a Sunday"
  />

  <section class="section-flow bg-paper py-20 lg:py-28">
    <div class="mx-auto max-w-8xl px-5 lg:px-8">
      <div class="reveal mx-auto max-w-3xl text-center richtext">
        <p class="text-lg">All our children's and youth workers are <strong>DBS-checked</strong>, well known within the church community, and vetted by church leadership — as well as being great fun and gifted at working with kids. We believe God can speak to us whatever our age.</p>
      </div>
      <div class="mt-14 grid gap-5 md:grid-cols-2">
        {groups.map((g, i) => (
          <div class="reveal rounded-[1.75rem] bg-ink/[0.03] p-9 ring-1 ring-ink/10" style={`--reveal-delay:${i * 100}ms`}>
            <span class="inline-flex rounded-full bg-clay px-4 py-1.5 font-display text-sm font-bold text-white">Ages {g.age}</span>
            <h2 class="mt-5 font-display text-3xl font-black text-ink">{g.name}</h2>
            <p class="mt-3 leading-relaxed text-ink/70">{g.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-flow grain bg-teal py-20 text-paper lg:py-24">
    <div class="mx-auto max-w-3xl px-5 text-center lg:px-8">
      <h2 class="reveal font-display text-display font-black">Bring the whole family.</h2>
      <p class="reveal mx-auto mt-5 max-w-xl text-lg leading-relaxed text-paper/80" style="--reveal-delay:120ms">Groups run every Sunday during our 10:30am gathering. We'd love to meet your little ones.</p>
      <div class="reveal mt-9 flex flex-wrap justify-center gap-3" style="--reveal-delay:240ms">
        <Button href={link('/im-new')} variant="ghost">Plan your visit</Button>
        <Button href={link('/community/youth')} variant="outline">Youth ministry →</Button>
      </div>
    </div>
  </section>
</BaseLayout>
