---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Button from '../../components/Button.astro';
import { link } from '../../data/site';
import heroImg from '../../assets/img/church-life.jpg';

const values = [
  { title: 'Advancing the Kingdom', body: 'We want to see God’s rule and reign break into ordinary life in East Devon.' },
  { title: 'Restoring the Church', body: 'Building church life in line with the vibrant, Spirit-filled communities of the New Testament.' },
  { title: 'Making disciples', body: 'Helping one another grow as wholehearted, lifelong followers of Jesus.' },
  { title: 'Training leaders', body: 'Raising up and releasing people to serve, lead and start new things.' },
  { title: 'Starting churches', body: 'Playing our part in planting healthy churches at home and beyond.' },
  { title: 'Reaching the nations', body: 'Joining a global family on mission, with over 850 churches in 60+ nations.' },
];
---
<BaseLayout title="Our Vision & Values" description="The vision and values that shape The Community Church, Honiton.">
  <PageHero
    eyebrow="About us"
    title="Our vision & values."
    subtitle="A simple vision, shared with a worldwide family: to see lives changed by Jesus, and the church flourish for the good of everyone around us."
    image={heroImg}
    imageAlt="The church family worshipping together"
  />

  <section class="section-flow bg-paper py-20 lg:py-28">
    <div class="mx-auto max-w-3xl px-5 lg:px-8">
      <div class="reveal rounded-[2rem] bg-ink p-10 text-paper lg:p-14">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay-400">Our vision</p>
        <p class="mt-5 font-display text-2xl font-bold leading-snug lg:text-3xl">To see ordinary people across East Devon meet Jesus, become wholehearted followers of his, and together make a difference in our community.</p>
      </div>
    </div>

    <div class="mx-auto mt-16 max-w-8xl px-5 lg:px-8">
      <div class="reveal max-w-2xl">
        <p class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-clay">What we value</p>
        <h2 class="mt-4 font-display text-display font-black text-ink">Six commitments we share.</h2>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {values.map((v, i) => (
          <div class="reveal rounded-[1.5rem] bg-ink/[0.03] p-7 ring-1 ring-ink/10" style={`--reveal-delay:${i * 60}ms`}>
            <span class="font-display text-3xl font-black text-clay/30">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mt-3 font-display text-xl font-bold text-ink">{v.title}</h3>
            <p class="mt-2 leading-relaxed text-ink/70">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-flow grain bg-teal py-20 text-paper lg:py-24">
    <div class="mx-auto max-w-3xl px-5 text-center lg:px-8">
      <h2 class="reveal font-display text-display font-black">Want the full picture?</h2>
      <p class="reveal mx-auto mt-5 max-w-xl text-lg leading-relaxed text-paper/80" style="--reveal-delay:120ms">Read more about the family of churches we belong to, and what we believe.</p>
      <div class="reveal mt-9 flex flex-wrap justify-center gap-3" style="--reveal-delay:240ms">
        <Button href={link('/about/family-of-churches')} variant="ghost">Our family of churches</Button>
        <Button href={link('/about/what-we-believe')} variant="outline">What we believe</Button>
      </div>
    </div>
  </section>
</BaseLayout>
