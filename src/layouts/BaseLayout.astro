---
// Self-hosted fonts (no external requests, no layout shift).
import '@fontsource/archivo/600.css';
import '@fontsource/archivo/700.css';
import '@fontsource/archivo/800.css';
import '@fontsource/archivo/900.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';

import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DemoRibbon from '../components/DemoRibbon.astro';
import { site, link } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  overHero?: boolean;
}
const { title, description = site.tagline, overHero = true } = Astro.props;
const fullTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.location}`;

// Load the single site-settings entry so its theme tokens override the defaults
// in global.css at build time. If the collection entry is missing (e.g. the file
// was accidentally deleted), we fall back gracefully to the hardcoded CSS defaults.
const settingsEntries = await getCollection('site-settings');
const themeSettings = settingsEntries[0]?.data ?? null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <!-- This is a concept demo: keep it out of search engines so it can't be mistaken for the live site. -->
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href={link('/favicon.png')} />
    <meta name="theme-color" content="#14100E" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {themeSettings && (
      // Inject CMS-controlled theme tokens as CSS custom-property overrides so
      // the admin can recolour the site by editing site-settings/settings.json.
      // This block sits after global.css (which defines the :root defaults) so
      // specificity wins automatically — no !important needed.
      <style set:html={`
        :root {
          --clay: ${themeSettings.colorClay};
          --paper: ${themeSettings.colorPaper};
          --ink: ${themeSettings.colorInk};
        }
      `} />
    )}
  </head>
  <body>
    <DemoRibbon />
    <Header overHero={overHero} />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Progressive scroll-reveal: elements with .reveal fade/slide in once. If JS or
      // IntersectionObserver is unavailable, everything is shown immediately (no hidden content).
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      if (els.length && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
